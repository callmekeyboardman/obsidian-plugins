{
  "name": "obsidian-all-file-viewer",
  "version": "1.0.0",
  "description": "Show and open non-native files (Excel, Word, PPT, etc.) in Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "file",
    "external",
    "excel",
    "word"
  ],
  "author": "shimengjie",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.18.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.17.19",
    "obsidian": "^1.4.11",
    "tslib": "^2.6.2",
    "typescript": "^4.9.5"
  }
}
